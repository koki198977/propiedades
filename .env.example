# ============================================================
# BASE DE DATOS
# ============================================================
DATABASE_URL="postgresql://admin:secret@localhost:5433/propiedades_db"

# ============================================================
# JWT
# ============================================================
JWT_SECRET="change-this-to-a-very-long-random-secret-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-very-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# API CONFIG
# ============================================================
API_PORT=3000
API_PREFIX=v1
NODE_ENV=development

# ============================================================
# CLOUDINARY
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="propiedades"

# ============================================================
# OPENAI (Agente IA)
# ============================================================
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o"
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.2

# ============================================================
# EMAIL (Nodemailer)
# ============================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Sistema Propiedades <your-email@gmail.com>"

# ============================================================
# FRONTEND (Vite)
# ============================================================
VITE_API_URL="http://localhost:3000/v1"
