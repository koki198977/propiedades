generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  passwordHash  String
  fullName      String
  role          UserRole             @default(ADMIN)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  conversations AiConversation[]
  expenses      Expense[]            @relation("ExpenseRecordedBy")
  notifications Notification[]
  organizations OrganizationMember[]
  payments      Payment[]            @relation("RecordedBy")
  properties    Property[]
  tenants       Tenant[]
  utilities     Utility[]            @relation("UtilityRecordedBy")

  @@map("users")
}

model Organization {
  id                String               @id @default(uuid())
  name              String
  slug              String               @unique
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  bankName          String?
  bankAccountType   String?
  bankAccountNumber String?
  bankAccountRut    String?
  bankAccountEmail  String?
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  members           OrganizationMember[]
  properties        Property[]
  tenants           Tenant[]

  @@map("organizations")
}

model ExpenseCategory {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("expense_categories")
}

model OrganizationMember {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(ADMIN)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Property {
  id              String            @id @default(uuid())
  organizationId  String?
  userId          String
  category        PropertyCategory
  name            String?
  address         String
  city            String?
  bedrooms        Int?
  bathrooms       Int?
  m2Total         Float?
  m2Built         Float?
  hasParking      Boolean           @default(false)
  hasStorage      Boolean           @default(false)
  rol             String?
  contractEndDate DateTime?
  paymentDueDay   Int
  notes           String?
  customCategory  String?
  expectedRent    Int?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  reminders       ExpenseReminder[]
  expenses        Expense[]
  organization    Organization?     @relation(fields: [organizationId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  meters          PropertyMeter[]
  photos          PropertyPhoto[]
  tenants         PropertyTenant[]
  utilities       Utility[]

  @@index([userId])
  @@index([organizationId])
  @@map("properties")
}

model PropertyPhoto {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  publicId   String
  order      Int      @default(0)
  uploadedAt DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_photos")
}

model PropertyMeter {
  id         String   @id @default(uuid())
  propertyId String
  label      String
  number     String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_meters")
}

model Utility {
  id               String      @id @default(uuid())
  propertyId       String
  type             UtilityType
  amount           Decimal     @db.Decimal(12, 2)
  isIncludedInRent Boolean     @default(true)
  billingMonth     DateTime?
  notes            String?
  recordedById     String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  property         Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  recordedBy       User?       @relation("UtilityRecordedBy", fields: [recordedById], references: [id])

  @@index([propertyId])
  @@map("utilities")
}

model ExpenseReminder {
  id          String           @id @default(uuid())
  propertyId  String
  title       String
  amount      Decimal          @db.Decimal(12, 2)
  frequency   ExpenseFrequency
  nextDueDate DateTime
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  property    Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("expense_reminders")
}

model Tenant {
  id             String           @id @default(uuid())
  organizationId String?
  userId         String
  name           String
  email          String?
  phone          String?
  documentId     String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  properties     PropertyTenant[]
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("tenants")
}

model PropertyTenant {
  id                        String    @id @default(uuid())
  propertyId                String
  tenantId                  String
  startDate                 DateTime
  endDate                   DateTime?
  monthlyRent               Decimal   @db.Decimal(12, 2)
  securityDeposit           Decimal?  @db.Decimal(12, 2)
  isSecurityDepositReturned Boolean   @default(false)
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  payments                  Payment[]
  property                  Property  @relation(fields: [propertyId], references: [id])
  tenant                    Tenant    @relation(fields: [tenantId], references: [id])

  @@index([propertyId])
  @@index([tenantId])
  @@index([isActive])
  @@map("property_tenants")
}

model Payment {
  id               String         @id @default(uuid())
  propertyTenantId String
  recordedById     String
  amount           Decimal        @db.Decimal(12, 2)
  paymentDate      DateTime
  paymentMethod    PaymentMethod
  receiptUrl       String?
  notes            String?
  createdAt        DateTime       @default(now())
  propertyTenant   PropertyTenant @relation(fields: [propertyTenantId], references: [id])
  recordedBy       User           @relation("RecordedBy", fields: [recordedById], references: [id])

  @@index([propertyTenantId])
  @@index([paymentDate])
  @@map("payments")
}

model Expense {
  id             String       @id @default(uuid())
  organizationId String
  propertyId     String?
  amount         Decimal      @db.Decimal(12, 2)
  date           DateTime
  category       String?
  description    String
  recordedById   String?
  isHistorical   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property?    @relation(fields: [propertyId], references: [id])
  recordedBy     User?        @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])

  @@index([organizationId])
  @@index([propertyId])
  @@map("expenses")
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum OrganizationRole {
  ADMIN
  EDITOR
  VIEWER
}

enum PropertyCategory {
  HOUSE
  APARTMENT
  OFFICE
  LAND
  OTHER
}

enum UtilityType {
  ELECTRICITY
  WATER
  GAS
  INTERNET
  TAX
  COMMON_EXPENSES
  INSURANCE
  GARBAGE
  WITHDRAWAL
  PERSONAL
  OTHER
}

enum PaymentMethod {
  CASH
  TRANSFER
  DEPOSIT
  CHECK
  OTHER
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ExpenseFrequency {
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum NotificationType {
  EXPIRATION
  PAYMENT_DUE
  EXPENSE_DUE
  SYSTEM
}
